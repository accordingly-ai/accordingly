# Worker secrets (set via `wrangler secret put` in prod)
OPENAI_API_KEY=

# Google Drive integration (browser-only PKCE; values are public)
# These are loaded by Vite at build time. See CLAUDE.md → External integrations.
# For prod, set these in the committed `.env.production` (not the Cloudflare dashboard).
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_PICKER_APP_ID=
