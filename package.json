{
  "name": "@accordingly/coordinator",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm typecheck && pnpm test && vite build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:client": "vitest run --project client",
    "test:worker": "vitest run --project worker",
    "typecheck": "tsc --noEmit",
    "forms:extract": "tsx scripts/extract-acord-fields.ts",
    "fixtures:pdf": "tsx scripts/convert-fixture-md-to-pdf.ts",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "itty-router": "^5.0.23",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.0.2",
    "marked": "^18.0.2",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.0",
    "wrangler": "^4.78.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  }
}
